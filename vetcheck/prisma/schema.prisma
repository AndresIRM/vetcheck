generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  email        String   @unique
  role         UserRole @default(ADMIN)
  firstName    String?
  lastName     String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lat          Decimal? @db.Decimal(9, 6)
  lng          Decimal? @db.Decimal(9, 6)

  vaccineRecords       VaccineRecord[]       @relation("VaccineRecordCreatedBy")
  studyRecords         StudyRecord[]         @relation("StudyRecordCreatedBy")
  surgeryRecords       SurgeryRecord[]       @relation("SurgeryRecordCreatedBy")
  reminders            Reminder[]            @relation("ReminderCreatedBy")
  generalConsultations GeneralConsultation[] @relation("GeneralConsultationCreatedBy")
}

model Owner {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  email        String   @unique
  phone        String
  firstName    String?
  lastName     String?
  pets         Pet[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Pet {
  id                   String                @id @default(cuid())
  shortId              String                @unique @db.VarChar(5)
  status               PetStatus             @default(ACTIVE)
  name                 String
  sex                  PetSex?
  breed                String?
  color                String?
  birthDate            DateTime?
  weight               Float?
  allergies            String?
  notes                String?
  ownerId              String
  owner                Owner                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  petTypeId            Int
  petType              PetType               @relation(fields: [petTypeId], references: [id])
  appointments         Appointment[]
  vaccineRecords       VaccineRecord[]
  studyRecords         StudyRecord[]
  surgeryRecords       SurgeryRecord[]
  generalConsultations GeneralConsultation[]
  reminders            Reminder[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model PetType {
  id        Int      @id @default(autoincrement())
  type      String   @unique
  pets      Pet[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  price        Float
  durationMin  Int?
  isActive     Boolean       @default(true)
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Appointment {
  id        String            @id @default(cuid())
  ownerName String
  phone     String
  email     String
  petId     String
  pet       Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  serviceId Int
  service   Service           @relation(fields: [serviceId], references: [id])
  date      DateTime
  reason    String?
  notes     String?
  status    AppointmentStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model VaccineRecord {
  id              String  @id @default(cuid())
  petId           String
  createdByUserId String?

  pet           Pet   @relation(fields: [petId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("VaccineRecordCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  vaccineName      String
  doseNumber       Int?
  applicationDate  DateTime
  nextDoseDate     DateTime?
  batchNumber      String?
  manufacturer     String?
  veterinarianName String?
  notes            String?
  status           RecordStatus @default(ACTIVE)
  reminders        Reminder[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model StudyRecord {
  id              String  @id @default(cuid())
  petId           String
  createdByUserId String?

  pet           Pet   @relation(fields: [petId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("StudyRecordCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  studyType       StudyType
  studyName       String
  studyDate       DateTime
  resultSummary   String?
  fileUrl         String?
  nextControlDate DateTime?
  notes           String?
  status          RecordStatus @default(ACTIVE)
  reminders       Reminder[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model SurgeryRecord {
  id              String  @id @default(cuid())
  petId           String
  createdByUserId String?

  pet           Pet   @relation(fields: [petId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("SurgeryRecordCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  surgeryName        String
  surgeryDate        DateTime
  diagnosis          String?
  procedureDetails   String?
  postoperativeNotes String?
  nextCheckDate      DateTime?
  status             RecordStatus @default(ACTIVE)
  reminders          Reminder[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Reminder {
  id              String  @id @default(cuid())
  petId           String
  createdByUserId String?

  pet           Pet   @relation(fields: [petId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("ReminderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  type        ReminderType
  title       String
  description String?
  remindAt    DateTime
  status      ReminderStatus @default(PENDING)
  sentAt      DateTime?

  vaccineRecordId String?
  vaccineRecord   VaccineRecord? @relation(fields: [vaccineRecordId], references: [id], onDelete: SetNull)

  studyRecordId String?
  studyRecord   StudyRecord? @relation(fields: [studyRecordId], references: [id], onDelete: SetNull)

  surgeryRecordId String?
  surgeryRecord   SurgeryRecord? @relation(fields: [surgeryRecordId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GeneralConsultation {
  id              String  @id @default(cuid())
  petId           String
  createdByUserId String?

  reason           String
  diagnosis        String?
  generalNotes     String?
  treatment        String?
  nextRevisionDate DateTime?
  status           RecordStatus @default(ACTIVE)

  pet           Pet   @relation(fields: [petId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("GeneralConsultationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  VET
  RECEPTIONIST
}

enum PetSex {
  MALE
  FEMALE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum RecordStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum StudyType {
  LAB
  XRAY
  ULTRASOUND
  BLOODWORK
  URINE
  STOOL
  OTHER
}

enum ReminderType {
  VACCINE
  STUDY
  SURGERY
  FOLLOW_UP
  DEWORMING
  GROOMING
  APPOINTMENT
  OTHER
}

enum ReminderStatus {
  PENDING
  SENT
  CANCELLED
}

enum PetStatus {
  ACTIVE
  INACTIVE
}
